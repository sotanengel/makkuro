{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sotanengel/makkuro/blob/main/src/makkuro/schema/makkuro.schema.json",
  "title": "makkuro configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "enum": [1]
    },
    "proxy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": {"type": "integer", "minimum": 1024, "maximum": 65535, "default": 8787},
        "bind": {"type": "string", "default": "127.0.0.1"},
        "shutdown_timeout_sec": {"type": "integer", "minimum": 0, "maximum": 300, "default": 5},
        "max_body_mb": {"type": "integer", "minimum": 1, "maximum": 256, "default": 16},
        "request_timeout_sec": {"type": "integer", "minimum": 1, "maximum": 3600, "default": 120}
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {"type": "string", "enum": ["mask", "block", "warn"], "default": "mask"},
        "rehydrate": {"type": "boolean", "default": true},
        "response_redaction": {"type": "boolean", "default": false}
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean", "default": true},
        "path": {"type": ["string", "null"]},
        "level": {"type": "string", "enum": ["debug", "info", "warn", "error"], "default": "info"},
        "rotate_mb": {"type": "integer", "minimum": 1, "maximum": 10000, "default": 50},
        "retention_days": {"type": "integer", "minimum": 1, "maximum": 3650, "default": 30}
      }
    },
    "providers": {
      "type": "object",
      "properties": {
        "default_timeout_sec": {"type": "integer", "minimum": 1, "maximum": 3600, "default": 60},
        "default_retries": {"type": "integer", "minimum": 0, "maximum": 10, "default": 2}
      },
      "patternProperties": {
        "^[a-z][a-z0-9_]*$": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "upstream": {"type": "string", "format": "uri", "pattern": "^https://"},
            "enabled": {"type": "boolean", "default": true},
            "protocol": {"type": "string", "enum": ["anthropic", "openai", "gemini"]}
          }
        }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "integrity_check": {"type": "boolean", "default": false},
        "network_allowlist_strict": {"type": "boolean", "default": true}
      }
    },
    "vault": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backend": {"type": "string", "enum": ["age", "keychain", "memory"], "default": "memory"},
        "path": {"type": "string"},
        "identity_path": {"type": "string"},
        "keychain_service": {"type": "string", "default": "makkuro"},
        "purge_after_days": {"type": "integer", "minimum": 0, "maximum": 3650, "default": 7},
        "rotate_reminder_days": {"type": "integer", "minimum": 0, "maximum": 3650, "default": 90}
      }
    },
    "telemetry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "metrics_enabled": {"type": "boolean", "default": true},
        "metrics_bind": {"type": "string", "default": "127.0.0.1:8788"},
        "otel_enabled": {"type": "boolean", "default": false},
        "otel_endpoint": {"type": "string"}
      }
    },
    "experimental": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mcp_deep_redact": {"type": "boolean", "default": true},
        "streaming_buffer_bytes": {"type": "integer", "minimum": 64, "maximum": 16384, "default": 512},
        "http2": {"type": "boolean", "default": false},
        "prompt_cache_safe_mode": {"type": "boolean", "default": true}
      }
    }
  }
}
